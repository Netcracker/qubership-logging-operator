{
  "description": "Programmatic supplements for stage-1 enable grading — run against worktree after enable. Scripts live in the eval workspace, not the published skill.",
  "stage": "enable",
  "skill_name": "qubership-ndjson-logging-enable",
  "workspace_scripts": "../qubership-ndjson-logging-migration-workspace/scripts",
