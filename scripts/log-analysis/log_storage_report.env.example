# Backend: graylog or victorialogs.
BACKEND_TYPE=graylog
BACKEND_URL=https://graylog.example.com

# Graylog credentials. Used only when BACKEND_TYPE=graylog.
GRAYLOG_USER=user
GRAYLOG_PASS=password

# VictoriaLogs credentials. Used only when BACKEND_TYPE=victorialogs.
VL_USER=
VL_PASS=

# VictoriaMetrics or vmauth endpoint used for filesystem metrics.
VICTORIAMETRICS_URL=http://victoria-metrics:8428
VM_USER=
VM_PASS=

# Analysis settings.
TIME_RANGE=24h
TIME_OFFSET=0s
SOURCE_FIELD=container
SYSTEM_SOURCE_FIELDS=nodename
AUDIT_SOURCE_FIELDS=namespace,container
TOP_LIMIT=50
INCLUDE_VL_BLOCK_STATS=false
# VictoriaLogs only. Graylog already includes aggregated level statistics.
INCLUDE_DETAILED_LEVELS=false
PARALLEL_QUERIES=true
GRAYLOG_QUERY_WORKERS=4
FIELDS_COUNT_THRESHOLD=20
# Thresholds accept plain KB or explicit units: 60, 60KB, 1MB.
GRAYLOG_LARGE_RECORD_THRESHOLD_KB=60
VL_LARGE_MESSAGE_THRESHOLD_KB=60
# Deprecated alias. Used only when backend-specific thresholds are not set.
LARGE_MESSAGE_THRESHOLD_KB=
ERROR_LEVEL_PERCENT_THRESHOLD=10
SINGLE_SOURCE_PERCENT_THRESHOLD=20
FILESYSTEM_SELECTOR='instance="logging-node:9100",mountpoint="/data"'
OUTPUT=log-storage-report.json
HTML_OUTPUT=log-storage-report.html

# Optional flags. Accepted true values: 1, true, yes, on.
INSECURE_SKIP_VERIFY=false
DRY_RUN=false
